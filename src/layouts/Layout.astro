---
import Footer from "../components/organisms/Footer.astro";
import Navbar from "../components/organisms/Navbar.astro";
import { SITE_TITLE } from "../lib/constants";

const { title = "A minimalist blog showcasing thoughtful content" } = (Astro.props as Props);
interface Props {
  title?: string;
  class?: string;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{SITE_TITLE} - {title}</title>
    <meta name="description" content="A minimalist blog showcasing thoughtful content" />
    <meta name="author" content="Your Name" />

    <meta property="og:title" content="Minimalist Blog" />
    <meta
      property="og:description"
      content="A beautifully designed blog with an elegant, minimalist approach"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Astro will automatically inject styles here -->
  </head>
  <body>
    <div class={`flex flex-col min-h-screen ${Astro.props.class}`}>
      <Navbar />
      <slot />
      <Footer />
    </div>
  </body>

  <style>
    html,
    body {
      margin: 0;
      width: 100%;
      height: 100%;
    }
  </style>
</html>
