---
const { author } = Astro.props;
---

<div class="bg-card rounded-xl p-6 text-center hover:shadow-md transition-shadow">
  <div class="flex justify-center mb-4">
    <img src={author.avatarUrl} alt={author.name} class="w-24 h-24 rounded-full object-cover" />
  </div>
  <h3 class="text-xl font-semibold mb-2">{author.name}</h3>
  <p class="text-muted-foreground text-sm mb-4">
    {author.bio}
  </p>
  <p class="text-sm font-medium text-primary mb-4">{author.articleCount} Articles</p>
  <a
    href={`/author/${author.id}`}
    class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring bg-primary text-primary-foreground hover:bg-primary/90 h-9 px-4 py-2"
  >
    View Profile
  </a>
</div>
